PORT=5000
MONGODB_URI=mongodb://localhost:27017/rumi-db
# Quote values that contain $ or spaces — otherwise dotenv may parse the rest of the file incorrectly.
MONGO_PASSWORD="your_password"
JWT_SECRET=your_jwt_secret_here

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini (AI assistant on the landing page)
GEMINI_API_KEY="your_gemini_api_key"

# Google Login (OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:9090/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:9090
