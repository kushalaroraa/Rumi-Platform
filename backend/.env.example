PORT=9090
MONGODB_URI=mongodb://localhost:27017/rumi-db
MONGO_USERNAME=your_username
# Quote values that contain $ or spaces -- otherwise dotenv may parse the rest of the file incorrectly.
MONGO_PASSWORD="your_password"
MONGO_DB_NAME=your_db_name
JWT_SECRET=your_jwt_secret_here

# Cloudinary Config
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini (AI assistant on the landing page)
GEMINI_API_KEY="your_gemini_api_key"

# Optional preferred model. If this model fails, backend falls back automatically.
# GEMINI_MODEL=gemini-2.5-flash

# Optional comma-separated fallback list override (advanced)
# GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# Google OAuth login
BACKEND_URL=http://localhost:9090
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
# Must match the Authorized redirect URI in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:9090/api/auth/google/callback
